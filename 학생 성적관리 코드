#include <stdio.h>

int main() {
    int score[5];
    int i;
    int max, min, sum = 0;
    double avg;
    int count = 0;

    printf("학생 5명의 점수를 입력하세요.\n");

    for(i = 0; i < 5; i++) {
        scanf("%d", &score[i]);
    }

    max = score[0];
    min = score[0];

    for(i = 0; i < 5; i++) {
        sum += score[i];

        if(score[i] > max)
            max = score[i];

        if(score[i] < min)
            min = score[i];
    }

    avg = sum / 5.0;

    for(i = 0; i < 5; i++) {
        if(score[i] >= avg)
            count++;
    }

    printf("\n평균 : %.2lf\n", avg);
    printf("최고점 : %d\n", max);
    printf("최저점 : %d\n", min);
    printf("평균 이상 학생 수 : %d명\n", count);

    return 0;
}
