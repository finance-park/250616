#include <stdio.h>
#include <stdlib.h>
#include <time.h>

int main() {

    int answer;
    int num;
    int count = 0;

    srand(time(NULL));

    answer = rand() % 100 + 1;

    printf("숫자 맞추기 게임 시작!\n");

    while(1) {

        printf("숫자를 입력하세요 : ");
        scanf("%d", &num);

        count++;

        if(num > answer)
            printf("DOWN!\n");

        else if(num < answer)
            printf("UP!\n");

        else {
            printf("\n정답입니다!\n");
            printf("총 %d번 만에 성공했습니다.\n", count);
            break;
        }
    }

    return 0;
}
